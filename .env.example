# Database (asyncpg driver). In Docker, host is the compose service name "db".
DATABASE_URL=postgresql+asyncpg://appuser:apppassword@db:5432/appdb

# For the dev stage only and tests.
DATABASE_URL =sqlite+aiosqlite:///./app.db

# JWT signing key — generate a strong random value, e.g. `openssl rand -hex 64`
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Background cleanup
UNVERIFIED_USER_TTL_DAYS=2
CLEANUP_INTERVAL_SECONDS=3600

# Postgres container credentials (used by docker-compose to build DATABASE_URL)
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=appdb
